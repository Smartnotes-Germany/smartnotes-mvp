# -----------------------------------------------------------------------------
# Frontend (Vite, zur Laufzeit im Browser)
# Validierung über T3 Env in src/env.ts
# Pro Umgebung sollten Website und App denselben PostHog Project Key benutzen.
# -----------------------------------------------------------------------------
VITE_CONVEX_URL=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=/snph
VITE_POSTHOG_UI_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# Build (vite.config.ts)
# Validierung über T3 Env in vite.config.ts
# Wenn API_KEY und PROJECT_ID leer sind, wird kein Source-Map-Upload ausgeführt.
# -----------------------------------------------------------------------------
POSTHOG_SOURCEMAPS_API_KEY=
POSTHOG_SOURCEMAPS_PROJECT_ID=
POSTHOG_SOURCEMAPS_HOST=https://eu.i.posthog.com
POSTHOG_SOURCEMAPS_RELEASE_NAME=
POSTHOG_SOURCEMAPS_RELEASE_VERSION=

# -----------------------------------------------------------------------------
# Backend / Convex
# Diese Variablen werden NICHT aus .env.local geladen.
# Für mehr Infos bitte /docs/environment.md lesen.
# Setze sie stattdessen mit `pnpm exec convex env set <NAME> <WERT>`.
# Die folgenden Zeilen sind absichtlich auskommentiert und dienen nur als
# Referenz für die vollständige Konfiguration.
# -----------------------------------------------------------------------------
# GOOGLE_VERTEX_API_KEY=
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=us-central1
# ACCESS_CODE_ADMIN_SECRET=
# FILE_STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# POSTHOG_ENABLED=false
# POSTHOG_PROJECT_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_APP_ENV=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASEURL=https://cloud.langfuse.com
# OBSERVABILITY_MODE=balanced
# OBSERVABILITY_ALLOW_SENSITIVE_CAPTURE=false
# OBSERVABILITY_SENSITIVE_CAPTURE_UNTIL=
# OBSERVABILITY_HASH_SALT=
# OBSERVABILITY_FLUSH_ON_EXIT=true
# OBSERVABILITY_FLUSH_TIMEOUT_MS=300
# RETENTION_DAYS_ANALYTICS=180
# RETENTION_DAYS_POSTHOG_OUTBOX=30
# RETENTION_DAYS_RAW_CONTENT=14
