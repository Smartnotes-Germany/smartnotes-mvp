# -----------------------------------------------------------------------------
# Frontend (Vite, zur Laufzeit im Browser)
# Validierung über T3 Env in src/env.ts
# -----------------------------------------------------------------------------
VITE_CONVEX_URL=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# -----------------------------------------------------------------------------
# Build (vite.config.ts)
# Validierung über T3 Env in vite.config.ts
# Wenn API_KEY und PROJECT_ID leer sind, wird kein Source-Map-Upload ausgeführt.
# -----------------------------------------------------------------------------
POSTHOG_SOURCEMAPS_API_KEY=
POSTHOG_SOURCEMAPS_PROJECT_ID=
POSTHOG_SOURCEMAPS_HOST=https://eu.i.posthog.com
POSTHOG_SOURCEMAPS_RELEASE_NAME=
POSTHOG_SOURCEMAPS_RELEASE_VERSION=
